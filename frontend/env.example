# Configurações de Cupons de Desconto
# IMPORTANTE: Este arquivo é apenas um exemplo. 
# Crie um arquivo .env com suas próprias configurações.

# Código do cupom válido (obrigatório)
VITE_COUPON_CODE=SEU_CODIGO_AQUI

# Valor do desconto em reais (obrigatório)
# Exemplo: 25 para R$ 25,00 de desconto
VITE_COUPON_DISCOUNT_VALUE=25

# Instruções:
# 1. Copie este arquivo para .env
# 2. Substitua os valores pelos seus próprios
# 3. NUNCA commite o arquivo .env no Git
# 4. O arquivo .env já está no .gitignore
